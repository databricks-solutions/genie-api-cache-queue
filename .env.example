# =============================================================================
# Demo Notebook Environment Variables
# =============================================================================
# Copy to /Workspace/Users/<your-email>/.env and fill in your values.
# The notebook loads this via dotenv.
# =============================================================================

# App
APP_HOST        = https://genie-cache-queue-7474650836156271.aws.databricksapps.com
GATEWAY_ID      = <your-gateway-id>

# Genie (for direct API comparison — scenario 1)
GENIE_SPACE_ID  = <your-genie-space-id>

# Auth — PAT required for Databricks Apps OAuth proxy
# Generate at: Workspace → Settings → Developer → Access tokens
DATABRICKS_PAT  = dapi...
