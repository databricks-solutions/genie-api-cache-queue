# =============================================================================
# Demo Notebook Environment Variables
# =============================================================================
# This file is ONLY for running the demo_notebook.ipynb locally or in a
# Databricks workspace. It is NOT used by the app itself (the app gets its
# config from the Settings UI or PUT /api/config).
#
# Usage:
#   1. Copy this file to .env and fill in your values
#   2. The notebook reads these via os.getenv() or Databricks SDK
# =============================================================================

# Auth
DATABRICKS_TOKEN        =
LAKEBASE_SERVICE_TOKEN  = <client_id>:<client_secret>

# Genie Spaces
GENIE_HOST              = https://<workspace>.cloud.databricks.com
SPACE                   = <primary-genie-space-id>
SPACE_NAME              = Primary Space
APP_HOST                = https://<app-name>.aws.databricksapps.com

# Secondary space (optional — for multi-space demo)
SPACE_2                 =
SPACE_2_NAME            = Secondary Space

# Infrastructure
SQL_WAREHOUSE_ID        = <your-warehouse-id>
LAKEBASE_INSTANCE_NAME  = <your-lakebase-project>
LAKEBASE_SCHEMA         = public

# Cache
CACHE_TABLE_NAME        = cached_queries
SIMILARITY_THRESHOLD    = 0.92
CACHE_TTL_SECONDS       = 86400
MAX_QUERIES_PER_MINUTE  = 5
